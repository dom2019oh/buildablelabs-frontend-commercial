# Firebase — copy from Firebase Console > Project Settings > Your apps > Web app
# NOTE: Firebase client config is intentionally public. Security is enforced by Firestore Security Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Backend API — AI keys (OpenAI, Anthropic) live on the server, never the frontend
# Defaults to https://api.buildablelabs.dev in production
VITE_API_BASE=
